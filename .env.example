# Shared bearer token required on every /api/* request.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
APP_AUTH_TOKEN=

# Anthropic API key. Server-side only; never sent to the browser.
ANTHROPIC_API_KEY=

# Path to the SQLite conversation store.
# Override to point at a mounted volume in hosted environments.
CONVERSATIONS_DB_PATH=./conversations.db

# Optional Claude model override. Leave unset to use the SDK default.
# ANTHROPIC_MODEL=claude-sonnet-4-6
